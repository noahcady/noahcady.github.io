  <!-- CONTACT -->
  <section class="contact" id="contact">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-text reveal">
          <p class="section-label">Get in Touch</p>
          <h2 class="section-heading">Let's create something together</h2>
          <p>Have a project in mind or just want to say hello? I'd love to hear from you. Fill out the form and I'll get back to you within 48 hours.</p>
          <div class="contact-links">
            <a href="mailto:hello@noahcady.com" class="contact-link">
              <svg viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
