<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Color Grading | Noah Cady</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,500;0,700;1,500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/style.css">
  <script>
    (function() {
      var theme = localStorage.getItem('theme');
      if (!theme) {
        theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
      }
      document.documentElement.setAttribute('data-theme', theme);
    })();
  </script>
</head>
<body>

  <%- include('partials/nav', { page: 'color-grading' }) %>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <p class="section-label">Portfolio</p>
      <h1 class="page-title">Color Grading</h1>
      <p class="page-subtitle">Transforming raw footage into cinematic visuals through precise color work. Below is a selection of stills and frames showcasing my approach to color grading.</p>
    </div>
  </section>

  <!-- GALLERY -->
  <section class="gallery-section">
    <div class="container">
      <div class="gallery-grid" id="galleryGrid">

        <!--
          TO ADD IMAGES: Upload your color grading stills to the
          "Personal Brand Site Photos" folder on Hostinger, then add
          gallery items here using this format:

          <div class="gallery-item reveal">
            <img src="/photos/YOUR-FILENAME.jpg" alt="Description of the shot" loading="lazy">
          </div>
        -->

        <div class="gallery-empty reveal">
          <div class="gallery-empty-icon">
            <svg viewBox="0 0 24 24"><rect x="3" y="3" width="18" height="18" rx="2" ry="2"/><circle cx="8.5" cy="8.5" r="1.5"/><polyline points="21 15 16 10 5 21"/></svg>
          </div>
          <h3>Coming Soon</h3>
          <p>Color grading examples will be added here shortly. Check back soon to see stills and frames from my latest projects.</p>
        </div>

      </div>
    </div>
  </section>

  <!-- IMAGE LIGHTBOX -->
  <div class="image-lightbox" id="imageLightbox">
    <div class="lightbox-overlay"></div>
    <div class="lightbox-content">
      <button class="lightbox-close" aria-label="Close">&times;</button>
      <img class="lightbox-img" src="" alt="">
      <p class="lightbox-caption"></p>
    </div>
  </div>

  <%- include('partials/footer') %>

  <script src="/js/main.js?v=4"></script>

</body>
</html>